{
  "SmartShipLogging": {
    "PersistLogs": true
  },
  "ConnectionStrings": {
    "SmartShipIdentityServiceConnection": "__CONNECTION_STRING_FROM_ENV__"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/IdentityService-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "__JWT_SECRET_FROM_ENV__",
    "Issuer": "SmartShipAPI",
    "Audiences": [
      "SmartShipClient",
      "SmartShipClient2",
      "SmartShip.Gateway",
      "SmartShip.AdminService",
      "SmartShip.DocumentService",
      "SmartShip.ShipmentService",
      "SmartShip.TrackingService",
      "SmartShip.IdentityService",
      "SmartShip.NotificationService"
    ],
    "ExpiryMinutes": 60
  },
  "GoogleAuth": {
    "ClientId": "__GOOGLE_CLIENT_ID_FROM_ENV__"
  },
  "InternalServiceAuth": {
    "ApiKey": "__INTERNAL_API_KEY_FROM_ENV__"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "__RABBITMQ_USER_FROM_ENV__",
    "Password": "__RABBITMQ_PASS_FROM_ENV__",
    "VirtualHost": "/",
    "PrefetchCount": 10,
    "PublishMaxRetryAttempts": 3,
    "ConsumerMaxRetryAttempts": 3,
    "BaseRetryDelaySeconds": 2
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "TimeoutMs": 15000,
    "UseCredentials": true,
    "FromName": "SmartShip",
    "FromEmail": "__SMTP_FROM_EMAIL_FROM_ENV__",
    "Username": "__SMTP_USERNAME_FROM_ENV__",
    "Password": "__SMTP_PASSWORD_FROM_ENV__"
  }
}