{
  "ConnectionStrings": {
    "SmartShipIdentityServiceConnection": "__CONNECTION_STRING_FROM_ENV__"
  },
  "GoogleAuth": {
    "ClientId": "__GOOGLE_CLIENT_ID_FROM_ENV__"
  },
  "InternalServiceAuth": {
    "ApiKey": "__INTERNAL_API_KEY_FROM_ENV__"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "TimeoutMs": 15000,
    "UseCredentials": true,
    "FromName": "SmartShip"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}