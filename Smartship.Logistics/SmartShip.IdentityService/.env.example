## SmartShip IdentityService - Environment Variables Template
## Copy this file to .env and fill in the actual values.

# Database Connection
ConnectionStrings__SmartShipIdentityServiceConnection=Server=localhost,1433;Database=SmartShipIdentityDB;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;Encrypt=False;

# JWT Authentication
JwtSettings__Secret=YOUR_JWT_SECRET_KEY

# Google OAuth
GoogleAuth__ClientId=YOUR_GOOGLE_CLIENT_ID

# Internal Service API Key
InternalServiceAuth__ApiKey=YOUR_INTERNAL_API_KEY

# RabbitMQ Credentials
RabbitMq__UserName=guest
RabbitMq__Password=guest

# SMTP Credentials
Smtp__Username=YOUR_SMTP_EMAIL
Smtp__Password=YOUR_SMTP_APP_PASSWORD
Smtp__FromEmail=YOUR_FROM_EMAIL
