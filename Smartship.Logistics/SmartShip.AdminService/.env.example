## SmartShip AdminService - Environment Variables Template
## Copy this file to .env and fill in the actual values.

# Database Connection
ConnectionStrings__SmartShipAdminServiceConnection=Server=localhost,1433;Database=SmartShipAdminDb;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;Encrypt=False;

# JWT Authentication
JwtSettings__Secret=YOUR_JWT_SECRET_KEY

# RabbitMQ Credentials
RabbitMq__UserName=guest
RabbitMq__Password=guest
